 	AND ( CASE WHEN ISNULL($P{CHILD_DEFS}) THEN (findoc_def.acct_type = 'B' and child_prj_def.enabled and !child_prj_def.is_deleted) ELSE FIND_IN_SET(child_prj_def.name_singular,$P{CHILD_DEFS}) END)
	AND (!(FIND_IN_SET(parent_child_prj_def.extension_id,'shoptick.projects.simple') and !parent_child_prj.id = $P{PROJECT_ELEMENT_ID}
	) OR (IFNULL((SELECT IF( ((cf_def.caption LIKE '%show%' OR cf_def.caption LIKE '%print%' OR cf_def.caption LIKE '%include%') AND IFNULL(biz_cf_value.storage_string,'false') = 'true') 
OR (!(cf_def.caption LIKE '%show%' OR cf_def.caption LIKE '%print%' OR cf_def.caption LIKE '%include%') AND IFNULL(biz_cf_value.storage_string,'false') = 'false'),true,false)
FROM st_biz_custom_field_def as cf_def 
left join st_prj_element_custom_field_element_defs on st_prj_element_custom_field_element_defs.custom_field_def_id = cf_def.id
left join st_prj_project_element on st_prj_project_element.def_id = st_prj_element_custom_field_element_defs.element_def_id
left JOIN st_biz_custom_field_value as biz_cf_value ON (cf_def.id = biz_cf_value.custom_field_def_id AND (SELECT id from st_prj_element_custom_field_value where proj_element_id=st_prj_project_element.id and id = biz_cf_value.id) = biz_cf_value.id)
WHERE st_prj_project_element.id=$P{PROJECT_ELEMENT_ID}
AND cf_def.field_id='toggle_subfolders'),TRUE)))
	AND !child_prj.is_deleted
