			THEN CONCAT(lpad(parent_child_prj_4.ordinal+(SELECT count(id) from st_prj_project_element where PARENT_ID = parent_child_prj_4.PARENT_ID and ordinal = parent_child_prj_4.ordinal and !is_deleted and created_by_date < parent_child_prj_4.created_by_date),3,0),lpad(parent_child_prj_3.ordinal+(SELECT count(id) from st_prj_project_element where PARENT_ID = parent_child_prj_3.PARENT_ID and ordinal = parent_child_prj_3.ordinal and !is_deleted and created_by_date < parent_child_prj_3.created_by_date),3,0),lpad(parent_child_prj_2.ordinal+(SELECT count(id) from st_prj_project_element where PARENT_ID = parent_child_prj_2.PARENT_ID and ordinal = parent_child_prj_2.ordinal and !is_deleted and created_by_date < parent_child_prj_2.created_by_date),3,0),lpad(parent_child_prj.ordinal+(SELECT count(id) from st_prj_project_element where PARENT_ID = parent_child_prj.PARENT_ID and ordinal = parent_child_prj.ordinal and !is_deleted and created_by_date < parent_child_prj.created_by_date),3,0),lpad(child_prj.ordinal+(SELECT count(id) from st_prj_project_element where PARENT_ID = child_prj.PARENT_ID and ordinal = child_prj.ordinal and !is_deleted and created_by_date < child_prj.created_by_date),3,0))
