LEFT JOIN st_prj_project_element as termsPrj on children.id = termsPrj.id
LEFT JOIN st_fin_document as termdoc on termsPrj.id = termdoc.id
LEFT JOIN st_biz_terms as terms on terms.id = termdoc.payment_term_id

