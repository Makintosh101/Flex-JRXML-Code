		<![CDATA[###############################################################################################################################
######### SQUARE WAVE ELEMENT MASTER QUERY ####################################################################################
############ DO NOT MODIFY THIS SECTION #######################################################################################
###############################################################################################################################
SELECT
######### ELEMENT INFO #########
(SELECT last_edit_date from st_biz_custom_report where id =  $P{reportId}) as reportLastEditDate,
(SELECT report_name from st_biz_custom_report where id =  $P{reportId}) as reportName,
IF((SELECT report_name from st_biz_custom_report where id =  $P{reportId}) LIKE '%TESTING',true,false) as reportTesting,
prj.document_number as elementNumber,
prj_def.has_document_number as elementHasDocumentNumber,
prj_def.document_number_caption as elementNumberCaption,
prj.element_name as elementName,
prj_def.name_singular as elementDefinitionName,

parent_prj.document_number as parentElementNumber,
parent_prj_def.has_document_number as parentHasDocumentNumber,
parent_prj_def.document_number_caption as parentElementNumberCaption,
parent_prj.element_name as parentElementName,
parent_prj_def.name_singular as parentElementDefinitionName,

CASE
WHEN ISNULL(prj.parent_id) THEN prj.element_name
WHEN ISNULL(parent_prj.parent_id) THEN parent_prj.element_name
WHEN ISNULL(parent_prj_2.parent_id) THEN parent_prj_2.element_name
WHEN ISNULL(parent_prj_3.parent_id) THEN parent_prj_3.element_name
WHEN ISNULL(parent_prj_4.parent_id) THEN parent_prj_4.element_name
WHEN ISNULL(parent_prj_5.parent_id) THEN parent_prj_5.element_name
WHEN ISNULL(parent_prj_6.parent_id) THEN parent_prj_6.element_name
END as topLevelElementName,

CASE
WHEN ISNULL(prj.parent_id) THEN prj.document_number
WHEN ISNULL(parent_prj.parent_id) THEN parent_prj.document_number
WHEN ISNULL(parent_prj_2.parent_id) THEN parent_prj_2.document_number
WHEN ISNULL(parent_prj_3.parent_id) THEN parent_prj_3.document_number
WHEN ISNULL(parent_prj_4.parent_id) THEN parent_prj_4.element_name
WHEN ISNULL(parent_prj_5.parent_id) THEN parent_prj_5.element_name
WHEN ISNULL(parent_prj_6.parent_id) THEN parent_prj_6.element_name
END as topLevelElementNumber,

CASE
WHEN ISNULL(prj.parent_id) THEN prj_def.name_singular
WHEN ISNULL(parent_prj.parent_id) THEN parent_prj_def.name_singular
WHEN ISNULL(parent_prj_2.parent_id) THEN parent_prj_def_2.name_singular
WHEN ISNULL(parent_prj_3.parent_id) THEN parent_prj_def_3.name_singular
WHEN ISNULL(parent_prj_4.parent_id) THEN parent_prj_def_4.name_singular
WHEN ISNULL(parent_prj_5.parent_id) THEN parent_prj_def_5.name_singular
WHEN ISNULL(parent_prj_6.parent_id) THEN parent_prj_def_6.name_singular
END as topLevelElementDefinitionName,

CASE
WHEN ISNULL(prj.parent_id) THEN prj_def.has_document_number
WHEN ISNULL(parent_prj.parent_id) THEN parent_prj_def.has_document_number
