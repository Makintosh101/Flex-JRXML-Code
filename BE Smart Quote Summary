		<queryString language="SQL">
			<![CDATA[SELECT
 CAST(MAX(st_fin_total_block_row_def.ordinal)  as SIGNED) as ordinal,
       ANY_VALUE(st_fin_total_block_row_def.caption) as caption,  
       ANY_VALUE(st_fin_total_block_row_def.field_type) as field_type,
       IFNULL(SUM( CASE

    WHEN st_fin_total_block_row_def.field_type = 'totalPrice' THEN fsub.total_price
    WHEN st_fin_total_block_row_def.field_type = 'totalAppliedPayments' THEN fsub.total_applied_payments
    WHEN st_fin_total_block_row_def.field_type = 'salesTax' THEN fsub.sales_tax
    WHEN st_fin_total_block_row_def.field_type = 'balanceDue' THEN fsub.balance_due
    WHEN st_fin_total_block_row_def.field_type = 'costSubtotal' THEN fsub.cost_subtotal
    WHEN st_fin_total_block_row_def.field_type = 'discountablePrice' THEN fsub.discountable_price
    WHEN st_fin_total_block_row_def.field_type = 'margin' THEN fsub.margin
    WHEN st_fin_total_block_row_def.field_type = 'priceDiscount' THEN fsub.price_discount
    WHEN st_fin_total_block_row_def.field_type = 'priceSubtotal' THEN fsub.price_subtotal
    WHEN st_fin_total_block_row_def.field_type = 'profit' THEN fsub.profit
    WHEN st_fin_total_block_row_def.field_type = 'totalCost' THEN fsub.total_cost
    WHEN st_fin_total_block_row_def.field_type = 'totalPayment' THEN fsub.total_payment
    WHEN st_fin_total_block_row_def.field_type = 'discountableCost' THEN fsub.discountable_cost
    WHEN st_fin_total_block_row_def.field_type = 'totalDeprepTime' THEN fsub.total_deprep_time
    WHEN st_fin_total_block_row_def.field_type = 'discountableCost' THEN fsub.discountable_cost
    WHEN st_fin_total_block_row_def.field_type = 'totalPriceWithoutTax' THEN fsub.total_price_without_sales_tax
    WHEN st_fin_total_block_row_def.field_type = 'costDiscount' THEN fsub.cost_discount
    WHEN st_fin_total_block_row_def.field_type = 'replacementCost' THEN fsub.total_replacement_cost
    WHEN st_fin_total_block_row_def.field_type = 'totalPrepTime' THEN fsub.total_prep_time
    WHEN st_fin_total_block_row_def.field_type = 'spacerRow' THEN null
    ELSE crow_value.row_value              
       END) ,0)  AS row_value,
       SUM(CASE
    WHEN st_fin_total_block_row_def.field_type = 'custom' AND st_fin_total_block_row_def.custom_row_id IN (select
        st_fin_custom_document_row.id from st_biz_resource_type
          left join st_fin_fee_matrix_resource_type on st_fin_fee_matrix_resource_type.resource_type = st_biz_resource_type.id
          left join st_fin_fee_matrix on st_fin_fee_matrix.id = st_fin_fee_matrix_resource_type.fee_matrix
          left join st_fin_custom_document_row on st_fin_custom_document_row.fee_matrix_id = st_fin_fee_matrix.id
        where discount_enabled and !st_biz_resource_type.is_deleted and !st_fin_fee_matrix.is_deleted and calculation_mode = 'pre-discount') 
      THEN (fsub.price_discount*(fsub.discountable_price/crow_value.row_value)) END) as discountPortion,     
  IFNULL(MAX(custom_row.transient_calculation),0) AS transient_calculation,
  MAX(is_hidden_if_zero) as is_hidden_if_zero,
  MAX(st_fin_total_block_row_def.is_bold) as is_bold 

FROM st_prj_project_element AS prj
LEFT JOIN (
	SELECT 
	sub_prj.*

       FROM st_prj_project_element AS sub_prj
       CROSS JOIN (SELECT -- cross join custom field to save looking it up over and over again.
           (IFNULL((SELECT IF( ((cf_def.caption LIKE '%show%' OR cf_def.caption LIKE '%print%' OR cf_def.caption LIKE '%include%') AND IFNULL(biz_cf_value.storage_string,'false') = 'true') 
           OR (!(cf_def.caption LIKE '%show%' OR cf_def.caption LIKE '%print%' OR cf_def.caption LIKE '%include%') AND IFNULL(biz_cf_value.storage_string,'false') = 'false'),true,false)
         FROM st_biz_custom_field_def AS cf_def 
           LEFT JOIN st_prj_element_custom_field_element_defs ON st_prj_element_custom_field_element_defs.custom_field_def_id = cf_def.id
           LEFT JOIN st_prj_project_element ON st_prj_project_element.def_id = st_prj_element_custom_field_element_defs.element_def_id
           LEFT JOIN st_biz_custom_field_value AS biz_cf_value ON (cf_def.id = biz_cf_value.custom_field_def_id AND (SELECT id FROM st_prj_element_custom_field_value WHERE proj_element_id=st_prj_project_element.id AND id = biz_cf_value.id) = biz_cf_value.id)
         WHERE st_prj_project_element.id=$P{PROJECT_ELEMENT_ID}
         AND cf_def.field_id='toggle_subfolders' ORDER BY biz_cf_value.last_edit_date DESC LIMIT 1),TRUE)) as includeSubfolders) as includeSubfolders
       LEFT JOIN st_prj_element_definition AS sub_prj_def ON sub_prj.def_id = sub_prj_def.id
       LEFT JOIN st_prj_project_element AS parent_sub_prj ON (parent_sub_prj.ID = sub_prj.PARENT_ID) AND (!FIND_IN_SET("shoptick.projects.simple",CONCAT_WS(",",sub_prj_def.extension_id)) OR includeSubfolders.includeSubfolders) and sub_prj.id != $P{PROJECT_ELEMENT_ID} -- Don't join ancestry running on single element
       LEFT JOIN st_prj_element_definition AS parent_sub_prj_def ON parent_sub_prj.DEF_ID = parent_sub_prj_def.ID 
       LEFT JOIN st_prj_project_element AS parent_sub_prj_2 ON (parent_sub_prj_2.ID = parent_sub_prj.PARENT_ID) AND (!FIND_IN_SET("shoptick.projects.simple",CONCAT_WS(",",parent_sub_prj_def.extension_id,sub_prj_def.extension_id)) OR includeSubfolders.includeSubfolders) -- Stop joining ancestry if !includeSubfolders and we've already passed one subfolder
       LEFT JOIN st_prj_element_definition AS parent_sub_prj_def_2 ON parent_sub_prj_2.DEF_ID = parent_sub_prj_def_2.ID
       LEFT JOIN st_prj_project_element AS parent_sub_prj_3 ON (parent_sub_prj_3.ID = parent_sub_prj_2.PARENT_ID) AND (!FIND_IN_SET("shoptick.projects.simple",CONCAT_WS(",",parent_sub_prj_def_2.extension_id,parent_sub_prj_def.extension_id,sub_prj_def.extension_id)) OR includeSubfolders.includeSubfolders)
       LEFT JOIN st_prj_element_definition AS parent_sub_prj_def_3 ON parent_sub_prj_3.DEF_ID = parent_sub_prj_def_3.ID
       LEFT JOIN st_prj_project_element AS parent_sub_prj_4 ON (parent_sub_prj_4.ID = parent_sub_prj_3.PARENT_ID) AND (!FIND_IN_SET("shoptick.projects.simple",CONCAT_WS(",",parent_sub_prj_def_3.extension_id,parent_sub_prj_def_2.extension_id,parent_sub_prj_def.extension_id,sub_prj_def.extension_id)) OR includeSubfolders.includeSubfolders)
       LEFT JOIN st_prj_element_definition AS parent_sub_prj_def_4 ON parent_sub_prj_4.DEF_ID = parent_sub_prj_def_4.ID
       LEFT JOIN st_prj_project_element AS parent_sub_prj_5 ON (parent_sub_prj_5.ID = parent_sub_prj_4.PARENT_ID) AND (!FIND_IN_SET("shoptick.projects.simple",CONCAT_WS(",",parent_sub_prj_def_4.extension_id,parent_sub_prj_def_3.extension_id,parent_sub_prj_def_2.extension_id,parent_sub_prj_def.extension_id,sub_prj_def.extension_id)) OR includeSubfolders.includeSubfolders)
       LEFT JOIN st_prj_element_definition AS parent_sub_prj_def_5 ON parent_sub_prj_5.DEF_ID = parent_sub_prj_def_5.ID
       LEFT JOIN st_prj_project_element AS parent_sub_prj_6 ON (parent_sub_prj_6.ID = parent_sub_prj_5.PARENT_ID) AND (!FIND_IN_SET("shoptick.projects.simple",CONCAT_WS(",",parent_sub_prj_def_5.extension_id,parent_sub_prj_def_4.extension_id,parent_sub_prj_def_3.extension_id,parent_sub_prj_def_2.extension_id,parent_sub_prj_def.extension_id,sub_prj_def.extension_id)) OR includeSubfolders.includeSubfolders)
       LEFT JOIN st_prj_element_definition AS parent_sub_prj_def_6 ON parent_sub_prj_6.DEF_ID = parent_sub_prj_def_6.ID       

       WHERE 
       ($P{PROJECT_ELEMENT_ID} IN (sub_prj.id,parent_sub_prj.id,parent_sub_prj_2.id,parent_sub_prj_3.id,parent_sub_prj_4.id,parent_sub_prj_5.id,parent_sub_prj_6.id))
       AND (FIND_IN_SET(sub_prj_def.name_singular,$P{SUB_DEFS}))
       AND !sub_prj.is_deleted
) as sub_prj on 1

LEFT JOIN st_fin_document as fsub ON (fsub.id = sub_prj.id)
LEFT JOIN st_prj_project_element as sub_folder ON sub_folder.id = sub_prj.parent_id
LEFT JOIN st_prj_element_definition as sub_def ON (sub_def.id = sub_prj.def_id)
LEFT JOIN st_biz_status_option as sub_status ON (sub_prj.status_id = sub_status.id)
left join st_fin_document_view_def as sub_view_def on sub_view_def.document_def_id = sub_prj.def_id and sub_view_def.view_name = "Financial View"

LEFT JOIN -- Union st_fin_total_block_row_def with data from json 
       ((SELECT 
              UNHEX(HEX(JSON_UNQUOTE(JSON_EXTRACT($P{json_col}, CONCAT('$[', num, '].field_type'))))) field_type, 
              UNHEX(HEX(JSON_UNQUOTE(JSON_EXTRACT($P{json_col}, CONCAT('$[', num, '].caption'))))) caption, 
              UNHEX(HEX(JSON_UNQUOTE(JSON_EXTRACT($P{json_col}, CONCAT('$[', num, '].is_hidden_if_zero'))))) is_hidden_if_zero,
              UNHEX(HEX(JSON_UNQUOTE(JSON_EXTRACT($P{json_col}, CONCAT('$[', num, '].custom_row_id'))))) custom_row_id,  
              UNHEX(HEX(JSON_UNQUOTE(JSON_EXTRACT($P{json_col}, CONCAT('$[', num, '].ordinal'))))) ordinal,
              'xxx' as view_def_id,
              numbers.num as id,
              UNHEX(HEX(JSON_UNQUOTE(JSON_EXTRACT($P{json_col}, CONCAT('$[', num, '].is_bold'))))) is_bold
              FROM ( SELECT 
              installed_rank-1 as num from schema_version LIMIT 10 ) numbers
              HAVING caption IS NOT NULL) 
              UNION ALL
              (SELECT field_type, caption, is_hidden_if_zero, custom_row_id, ordinal, view_def_id, id, is_bold from st_fin_total_block_row_def)) 
       as st_fin_total_block_row_def on 
              CASE WHEN !ISNULL($P{json_col}) THEN 
                     st_fin_total_block_row_def.view_def_id = 'xxx' ELSE sub_view_def.id = st_fin_total_block_row_def.view_def_id END

LEFT JOIN st_fin_custom_document_row AS custom_row ON custom_row.id = st_fin_total_block_row_def.custom_row_id
                     
LEFT JOIN st_fin_custom_row_value AS crow_value ON crow_value.custom_row_id = st_fin_total_block_row_def.custom_row_id
       AND crow_value.fin_document_id = sub_prj.id
WHERE
prj.id = $P{PROJECT_ELEMENT_ID}

AND sub_status.status_name NOT LIKE '%Cancel%'

GROUP BY st_fin_total_block_row_def.id

ORDER BY ordinal ASC]]>
		</queryString>
