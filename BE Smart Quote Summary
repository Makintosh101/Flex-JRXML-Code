LEFT JOIN st_fin_document as fchild ON (fchild.id = child.id)
LEFT JOIN st_prj_project_element as child_folder ON child_folder.id = child.parent_id
LEFT JOIN st_prj_element_definition as child_def ON (child_def.id = child.def_id)
LEFT JOIN st_biz_status_option as child_status ON (child.status_id = child_status.id)
left join st_fin_document_view_def as child_view_def on child_view_def.document_def_id = child.def_id and child_view_def.ordinal = 0
