	LEFT JOIN st_prj_element_definition AS parent_child_prj_def_4 ON parent_child_prj_4.DEF_ID = parent_child_prj_def_4.ID
	LEFT JOIN st_prj_project_element AS parent_child_prj_5 ON (parent_child_prj_5.ID = parent_child_prj_4.PARENT_ID)
	LEFT JOIN st_prj_element_definition AS parent_child_prj_def_5 ON parent_child_prj_5.DEF_ID = parent_child_prj_def_5.ID
	LEFT JOIN st_prj_project_element AS parent_child_prj_6 ON (parent_child_prj_6.ID = parent_child_prj_5.PARENT_ID)
	LEFT JOIN st_prj_element_definition AS parent_child_prj_def_6 ON parent_child_prj_6.DEF_ID = parent_child_prj_def_6.ID	
	left join st_fin_document_def as findoc_def on findoc_def.id = child_prj.def_id

	WHERE 
