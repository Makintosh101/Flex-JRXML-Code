left join (SELECT 
GROUP_CONCAT(CASE WHEN ordinal = 1 THEN storage_string ELSE NULL END) as storage_string_1,
GROUP_CONCAT(CASE WHEN ordinal = 2 THEN storage_string ELSE NULL END) as storage_string_2,
GROUP_CONCAT(CASE WHEN ordinal = 3 THEN storage_string ELSE NULL END) as storage_string_3,
GROUP_CONCAT(CASE WHEN ordinal = 4 THEN storage_string ELSE NULL END) as storage_string_4,
GROUP_CONCAT(CASE WHEN ordinal = 5 THEN storage_string ELSE NULL END) as storage_string_5,
GROUP_CONCAT(CASE WHEN ordinal = 6 THEN storage_string ELSE NULL END) as storage_string_6,
GROUP_CONCAT(CASE WHEN ordinal = 7 THEN storage_string ELSE NULL END) as storage_string_7,
GROUP_CONCAT(CASE WHEN ordinal = 8 THEN storage_string ELSE NULL END) as storage_string_8,
GROUP_CONCAT(CASE WHEN ordinal = 9 THEN storage_string ELSE NULL END) as storage_string_9,
GROUP_CONCAT(CASE WHEN ordinal = 10 THEN storage_string ELSE NULL END) as storage_string_10,
element_id
FROM(SELECT CASE
WHEN prj_def_cf.field_type IN ('timestamp','date') THEN CAST(from_unixtime(storage_string/1000) as DATETIME)
WHEN prj_def_cf.field_type IN ('location','contact','employee','inventory') THEN (SELECT resource_name from st_biz_managed_resource where id = storage_string)
WHEN prj_def_cf.field_type = 'calendarTemplate' THEN (SELECT group_name from st_prj_calendar_template where id = storage_string)
WHEN prj_def_cf.field_type = 'currency' THEN (SELECT currency_name from st_biz_currency where id = storage_string)
WHEN prj_def_cf.field_type IN ('customReport','instance-report') THEN (SELECT report_name from st_biz_custom_report where id = storage_string)
WHEN prj_def_cf.field_type IN ('element-definition','document-definition') THEN (SELECT name_singular from st_prj_element_definition where id = storage_string)
WHEN prj_def_cf.field_type IN ('statusOption','definitionStatusOption') THEN (SELECT status_name from st_biz_status_option where id = storage_string)
WHEN prj_def_cf.field_type = 'inventory-group' THEN (SELECT group_name from st_ivt_inventory_group where id = storage_string)
WHEN prj_def_cf.field_type = 'scheduledInventoryCount' THEN (SELECT count_name from st_ivt_inventory_count where id = storage_string)
WHEN prj_def_cf.field_type IN ('stockTypes','serviceResourceType') THEN (SELECT resource_name from st_biz_resource_type where id = storage_string)
WHEN prj_def_cf.field_type = 'terms-conditions' THEN (SELECT content from st_biz_terms_conditions where id = storage_string)
WHEN prj_def_cf.field_type = 'pricingModel' THEN (SELECT name from st_biz_pricing_model where id = storage_string)
WHEN prj_def_cf.field_type = 'user-id' THEN (SELECT name from rh_userprofile where userprofileid = storage_string)
WHEN prj_def_cf.field_type = 'option-list' THEN (SELECT caption from st_prj_project_element_def_custom_field_list_options where id = storage_string)
ELSE storage_string END as storage_string, element_id, ordinal, prj_def_cf.field_type, prj_def_cf.caption FROM st_prj_project_element_def_custom_field_value as prj_def_cf_value
left join st_prj_project_element_def_custom_field as prj_def_cf on prj_def_cf.id = prj_def_cf_value.custom_field_id) custom_fields GROUP BY element_id) as custom_fields on custom_fields.element_id = prj.id
