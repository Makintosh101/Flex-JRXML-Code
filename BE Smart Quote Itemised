		<queryString language="SQL">
			<![CDATA[select

miniheader.caption,
CASE WHEN !ISNULL(miniheader.format_mask_type) THEN miniheader.format_mask_type
WHEN miniheader.field_type IN ('loadInDate','plannedStartDate','plannedEndDate','preparedDate','showStart','loadOutDate','dueDate','paymentDate','checkDate','depositDueDate','eventDate') THEN 'Time Stamp' 
END as format_mask_type,
miniheader.ordinal,
CASE
WHEN miniheader.field_type = 'loadInDate' THEN prj.load_in_date
WHEN miniheader.field_type = 'venue' THEN (SELECT resource_name from st_biz_managed_resource where id = prj.venue_id)
WHEN miniheader.field_type = 'preparedDate' THEN prj.prepared_date
WHEN miniheader.field_type = 'parentDocumentNumber' THEN parent_prj.document_number
WHEN miniheader.field_type = 'creator' THEN (SELECT name from rh_userprofile where userprofileid = prj.created_by_user)
WHEN miniheader.field_type = 'location' THEN (SELECT resource_name from st_biz_managed_resource where id=bizLoc.id)
WHEN miniheader.field_type = 'personResponsible' THEN (SELECT resource_name from st_biz_managed_resource where id = prj.person_responsible_id)
WHEN miniheader.field_type = 'parentDocumentName' THEN parent_prj.element_name
WHEN miniheader.field_type = 'totalPrepTime' THEN findoc.total_prep_time
WHEN miniheader.field_type = 'rootDocumentName' THEN null
WHEN miniheader.field_type = 'returnMethod' THEN (SELECT method_name FROM st_biz_shipping_method WHERE id = prj.return_method_id)
WHEN miniheader.field_type = 'showStart' THEN prj.show_start
WHEN miniheader.field_type = 'loadOutDate' THEN prj.load_out_date
WHEN miniheader.field_type = 'standardDiscount' THEN null
WHEN miniheader.field_type = 'corporateIdentity' THEN corp.company_name
WHEN miniheader.field_type = 'documentName' THEN prj.element_name
WHEN miniheader.field_type = 'clientNumber' THEN null
WHEN miniheader.field_type = 'totalDeprepTime' THEN findoc.total_deprep_time
WHEN miniheader.field_type = 'documentNumber' THEN prj.document_number 
WHEN miniheader.field_type = 'totalReplacementCost' THEN findoc.total_replacement_cost
WHEN miniheader.field_type = 'status' THEN (SELECT status.status_name from st_biz_status_option status where prj.status_id = status.id)
WHEN miniheader.field_type = 'rootDocumentNumber' THEN null
WHEN miniheader.field_type = 'clientInsurance' THEN null
WHEN miniheader.field_type = 'dateCreated' THEN prj.created_by_date
WHEN miniheader.field_type = 'referralSource' THEN null
WHEN miniheader.field_type = 'customerPO' THEN prj.customer_po
WHEN miniheader.field_type = 'dueDate' THEN prj.due_date
WHEN miniheader.field_type = 'insurableValue' THEN prj.insurable_value
WHEN miniheader.field_type = 'totalWeight' THEN findoc.total_weight
WHEN miniheader.field_type = 'client' THEN (SELECT resource_name from st_biz_managed_resource where id = prj.client_id)
WHEN miniheader.field_type = 'billTo' THEN (SELECT resource_name from st_biz_managed_resource where id = prj.bill_to_id)
WHEN miniheader.field_type = 'checkDate' THEN findoc.check_date
WHEN miniheader.field_type = 'eventPlanner' THEN (SELECT resource_name from st_biz_managed_resource where id = prj.event_planner_id)
WHEN miniheader.field_type = 'depositDueDate' THEN prj.deposit_due_date

END as value
from st_prj_project_element as prj
LEFT JOIN st_prj_project_element AS parent_prj ON (parent_prj.ID = prj.PARENT_ID)
LEFT JOIN st_biz_location as bizLoc ON (prj.location_id = bizLoc.id) -- Business Location (Warehouse of current project element )
LEFT JOIN st_biz_corp_identity as corp on corp.id = IFNULL(prj.corp_identity_id,(SELECT id from st_biz_corp_identity where is_hq)) -- Corp Identity of current project element
left join st_prj_element_definition as prj_def on prj_def.id = prj.def_id
left join st_fin_document_view_def as findoc_view_def on findoc_view_def.document_def_id = prj_def.id and findoc_view_def.ordinal = 0
left join st_fin_miniheader_col_def as miniheader on miniheader.view_def_id = findoc_view_def.id
LEFT JOIN st_fin_document as findoc ON (prj.id=findoc.id)
LEFT JOIN st_biz_terms as terms on (findoc.payment_term_id = terms.id)
where prj.id = $P{PROJECT_ELEMENT_ID} and FIND_IN_SET(miniheader.row_index,$P{MINIHEADER_ROW})  and miniheader.print_enabled


ORDER BY miniheader.ordinal]]>
