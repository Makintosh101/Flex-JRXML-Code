			<![CDATA[SELECT st_fin_total_block_row_def.field_type,
       st_fin_total_block_row_def.ordinal,
        st_fin_total_block_row_def.caption,
       st_fin_total_block_row_def.custom_row_id,
       CASE
           WHEN st_fin_total_block_row_def.field_type = 'priceSubtotal' THEN findoc.discountable_price
           WHEN st_fin_total_block_row_def.field_type = 'priceDiscount' THEN (findoc.price_discount*-1)
           WHEN st_fin_total_block_row_def.field_type = 'salesTax' THEN findoc.sales_tax
           WHEN st_fin_total_block_row_def.field_type = 'totalPrice' THEN findoc.total_price
           WHEN st_fin_total_block_row_def.field_type = 'totalAppliedPayments' THEN findoc.total_applied_payments
           WHEN st_fin_total_block_row_def.field_type = 'balanceDue' THEN findoc.balance_due
           WHEN st_fin_total_block_row_def.field_type = 'totalPriceWithoutTax'  THEN findoc.total_price_without_sales_tax
 

 
           WHEN st_fin_total_block_row_def.field_type = 'custom' AND !$P{PRINT_DISCOUNT} AND st_fin_total_block_row_def.caption = 'Equipment'  THEN
                  (SELECT row_value
                   FROM st_fin_custom_row_value AS crow_value
                   WHERE crow_value.custom_row_id = st_fin_total_block_row_def.custom_row_id
                     AND crow_value.fin_document_id = $P{PROJECT_ELEMENT_ID}) - findoc.price_discount 
                        WHEN st_fin_total_block_row_def.field_type = 'custom' THEN
                  (SELECT row_value
                   FROM st_fin_custom_row_value AS crow_value
                   WHERE crow_value.custom_row_id = st_fin_total_block_row_def.custom_row_id
                     AND crow_value.fin_document_id = $P{PROJECT_ELEMENT_ID})               
       END AS row_value,

  IFNULL((SELECT transient_calculation
   FROM st_fin_custom_row_value AS crow_value
   LEFT JOIN st_fin_custom_document_row ON crow_value.custom_row_id = st_fin_custom_document_row.id
   WHERE crow_value.custom_row_id = st_fin_total_block_row_def.custom_row_id
     AND crow_value.fin_document_id = $P{PROJECT_ELEMENT_ID}),0) AS transient_calculation
FROM st_fin_document AS findoc
LEFT JOIN st_prj_project_element AS prj ON prj.id = findoc.id
LEFT JOIN st_fin_document_view_def ON st_fin_document_view_def.document_def_id = prj.def_id
AND st_fin_document_view_def.view_name = 'Financial View'
LEFT JOIN st_fin_total_block_row_def ON st_fin_document_view_def.id = st_fin_total_block_row_def.view_def_id
WHERE findoc.id = $P{PROJECT_ELEMENT_ID}
ORDER BY ordinal ASC]]>
