WHEN ISNULL(parent_prj.parent_id) THEN parent_prj_def.name_singular
WHEN ISNULL(parent_prj_2.parent_id) THEN parent_prj_def_2.name_singular
WHEN ISNULL(parent_prj_3.parent_id) THEN parent_prj_def_3.name_singular
WHEN ISNULL(parent_prj_4.parent_id) THEN parent_prj_def_4.name_singular
WHEN ISNULL(parent_prj_5.parent_id) THEN parent_prj_def_5.name_singular
WHEN ISNULL(parent_prj_6.parent_id) THEN parent_prj_def_6.name_singular
